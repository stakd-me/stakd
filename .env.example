# PostgreSQL
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=portfolio
POSTGRES_DB=portfolio
DATABASE_URL=postgresql://portfolio:portfolio@localhost:5432/portfolio

# Redis
REDIS_MAXMEMORY=64mb
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=production
APP_PORT=33000
JWT_SECRET=change-me-use-openssl-rand-hex-32
AUTH_FAKE_SALT_SECRET=change-me-use-openssl-rand-hex-32
TRUST_PROXY_IP_HEADERS=0
PRICES_BACKGROUND_REFRESH_ENABLED=1
PRICES_BACKGROUND_REFRESH_MINUTES=15
PRICE_HISTORY_RETENTION_DAYS=365
